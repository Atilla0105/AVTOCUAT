generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Template {
  id            String   @id @default(cuid())
  title         String
  topic         String
  style         String
  totalDuration Int
  content       String
  aiProvider    String
  isFavorite    Boolean  @default(false)
  tags          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VideoAnalysis {
  id             String   @id @default(cuid())
  videoUrl       String
  videoTitle     String
  videoPlatform  String
  transcript     String?
  frameCount     Int      @default(0)
  analysisResult String
  aiProvider     String
  createdAt      DateTime @default(now())
}

model Settings {
  id              String @id @default("default")
  defaultProvider String @default("claude")
  defaultStyle    String @default("vlog")
  anthropicKey    String @default("")
  openaiKey       String @default("")
  language        String @default("zh")
}
